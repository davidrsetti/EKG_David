# ── NEXUS Platform Environment Configuration ─────────────────────────
# Copy to .env and fill in your values.

# ── Stardog ───────────────────────────────────────────────────────────
STARDOG_ENDPOINT=http://localhost:5820/nexus/query
STARDOG_TOKEN=your-stardog-token-here
STARDOG_AUTH_SCHEME=Bearer
STARDOG_DB=nexus
STARDOG_VERIFY_TLS=false
STARDOG_TIMEOUT=30

# ── OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
SPARQL_MODEL=o3-mini          # reasoning model — best for multi-hop SPARQL
CLARIFY_MODEL=gpt-4o-mini     # fast + cheap for intent classification
ANSWER_MODEL=gpt-4o           # best prose for answer synthesis
GUARD_MODEL=gpt-4o-mini       # simple risk classification
LLM_MAX_TOKENS=2000

# ── Security ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-long-random-string
TOKEN_EXPIRE_MINS=480
RATE_LIMIT_PER_HOUR=60
MAX_RESULT_ROWS=500
MAX_SPARQL_COMPLEXITY=12

# ── Audit ─────────────────────────────────────────────────────────────
AUDIT_ENABLED=true
AUDIT_SINK=file                # file | postgres | azure_monitor
AUDIT_LOG_PATH=logs/nexus_audit.jsonl
AUDIT_DB_URL=                  # postgresql://user:pass@host/db

# ── Azure Monitor (if AUDIT_SINK=azure_monitor) ───────────────────────
AZURE_LOG_WORKSPACE_ID=
AZURE_LOG_KEY=

# ── Denodo (optional live data federation) ────────────────────────────
DENODO_ENABLED=false
DENODO_ENDPOINT=
DENODO_USER=
DENODO_PASSWORD=
DENODO_DATABASE=nexus_vdb

# ── Platform ──────────────────────────────────────────────────────────
NEXUS_ENV=development          # development | production
